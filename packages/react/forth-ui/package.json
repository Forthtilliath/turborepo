{
  "name": "@forthtilliath/forth-ui",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Forthtilliath/turborepo.git",
    "directory": "packages/react/forth-ui"
  },
  "homepage": "https://github.com/Forthtilliath/turborepo/tree/main/packages/react/forth-ui#readme",
  "bugs": "https://github.com/Forthtilliath/turborepo/issues",
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "concurrently \"pnpm:dev:ts\" \"pnpm:dev:tw\"",
    "dev:ts": "tsc --watch",
    "dev:tw": "pnpm run build:tw --watch",
    "build": "pnpm run clean && pnpm run build:ts && pnpm run build:tw",
    "build:ts": "tsc",
    "build:tw": "npx @tailwindcss/cli -i ./src/styles/globals.css -o ./dist/globals.css"
  },
  "dependencies": {
    "@forthtilliath/react-hooks": "workspace:*",
    "@forthtilliath/shadcn-ui": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "qrcode": "^1.5.4",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "@forthtilliath/eslint-config": "workspace:*",
    "@forthtilliath/types": "workspace:*",
    "@forthtilliath/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@turbo/gen": "catalog:",
    "@types/node": "catalog:",
    "@types/qrcode": "^1.5.6",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "concurrently": "^10.0.3",
    "eslint": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./components/*": "./dist/components/*/index.js",
    "./styles/globals.css": "./dist/globals.css"
  }
}

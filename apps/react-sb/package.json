{
  "name": "react-sb",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "preview": "vite preview",
    "dev:tw": "pnpm run build:tw --watch",
    "build:tw": "npx @tailwindcss/cli -i ./src/styles/globals.css -o ./.storybook/globals.css --watch",
    "build:tw:once": "npx @tailwindcss/cli -i ./src/styles/globals.css -o ./.storybook/globals.css",
    "prebuild-storybook": "pnpm run build:tw:once",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "qa:screenshot": "node scripts/screenshot.mjs"
  },
  "dependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@forthtilliath/eslint-config": "workspace:*",
    "@forthtilliath/forth-ui": "workspace:*",
    "@forthtilliath/react-ui": "workspace:*",
    "@forthtilliath/shadcn-ui": "workspace:*",
    "@forthtilliath/types": "workspace:*",
    "@forthtilliath/typescript-config": "workspace:*",
    "@storybook/addon-docs": "9.1.20",
    "@storybook/addon-themes": "9.1.20",
    "@storybook/addon-vitest": "9.1.20",
    "@storybook/react-vite": "9.1.20",
    "@tailwindcss/postcss": "catalog:",
    "@tanstack/react-table": "^8.21.3",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^3.2.7",
    "date-fns": "^4.4.0",
    "eslint": "catalog:",
    "eslint-plugin-storybook": "9.1.20",
    "lucide-react": "^1.24.0",
    "playwright": "^1.61.1",
    "storybook": "9.1.20",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "^7.3.6",
    "vitest": "^3.2.7",
    "zod": "^4.4.3"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}

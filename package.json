{
  "name": "@forthtilliath/turborepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:sb": "turbo run dev --filter=react-sb",
    "dev:forth-ui": "turbo run dev --filter=@forthtilliath/forth-ui",
    "dev:react-ui": "turbo run dev --filter=@forthtilliath/react-ui",
    "dev:lib": "turbo run dev --filter=@forthtilliath/lib",
    "dev:types": "turbo run dev --filter=@forthtilliath/types",
    "dev:eslint-config": "turbo run dev --filter=@forthtilliath/eslint-config",
    "build:forth-ui": "turbo run build --filter=@forthtilliath/forth-ui",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "publish-packages": "turbo run build lint && changeset version && changeset publish",
    "clean": "turbo run clean",
    "update": "pnpm update -r --latest",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.5",
    "taze": "^19.14.1",
    "tsup": "^8.5.1",
    "turbo": "^2.10.5",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=20.9"
  }
}
